{
  "name": "study-math-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:pages": "npm run build && wrangler pages dev dist --compatibility-date=2026-06-22",
    "build": "vite build && node scripts/write-deploy-version.mjs && cp dist/index.html dist/404.html",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "wrangler pages deploy dist --project-name study"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "firebase": "^11.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  }
}
